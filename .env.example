# Composio (free tier works) — powers COMPOSIO_SEARCH research tools + toolkit registry
COMPOSIO_API_KEY=

# OpenAI — all LLM stages. Distinct model lineages keep verifier/judge errors
# partially decorrelated from the researcher on a single provider.
OPENAI_API_KEY=
OPENAI_CHEAP_MODEL=gpt-5-mini     # Docs Scout + API Analyst (research)
OPENAI_SMART_MODEL=gpt-5-mini     # Fixer (raise to gpt-5.2 if budget allows)
VERIFY_MODEL=gpt-4o-mini          # Skeptic Verifier (tool-free, evidence injected)
JUDGE_MODEL=gpt-4.1-mini          # Eval judge (tool-free, evidence injected)

# Optional: OpenRouter for cross-provider verification (stronger independence).
# If set AND you change src/llms.py verifier()/judge() back to openrouter models,
# verification runs on a different provider entirely.
OPENROUTER_API_KEY=
